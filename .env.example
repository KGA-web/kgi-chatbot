KGI_CHATBOT_NAME=Koshys AI Assistant
KGI_CHATBOT_WELCOME=Welcome to Koshys Group of Institutions! I'm here to help you with admissions, courses, campus info, and more. How can I assist you today?

# Groq AI Configuration (Free tier - https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Sheets Configuration (Option 1: Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key_here
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# OR Google Apps Script (Option 2: Free, no service account needed)
# Get this from your Apps Script deployment (see apps_script.gs)
GOOGLE_APPS_SCRIPT_URL=your_apps_script_url_here

# Vercel/Production URL
NEXT_PUBLIC_API_URL=https://your-app.vercel.app